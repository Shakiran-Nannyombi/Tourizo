# Production Environment Variables
# Generate a secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Database URL
# Using SQLite (no external database needed)
# DATABASE_URL is optional - if not set, defaults to SQLite
# DATABASE_URL=sqlite:///instance/travel_app.db

# Flask Environment
FLASK_APP=run.py
FLASK_ENV=production

# Mail Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@tourizo.com

# Admin Email
ADMIN_EMAIL=admin@tourizo.com

# Upload Folder
UPLOAD_FOLDER=static/uploads

